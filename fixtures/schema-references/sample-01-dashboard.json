{
  "routes": [
    {
      "id": "route_dashboard",
      "path": "/dashboard",
      "name": "dashboard",
      "view": "view_dashboard"
    }
  ],
  "views": [
    {
      "id": "view_dashboard",
      "title": "运营看板",
      "layout": {
        "type": "grid",
        "columns": 24,
        "gap": 16
      },
      "rootComponentIds": ["cmp_dashboard_root"]
    }
  ],
  "components": [
    {
      "id": "cmp_dashboard_root",
      "type": "container",
      "props": {
        "direction": "vertical",
        "gap": 16
      },
      "children": ["cmp_kpi_row", "cmp_revenue_chart"]
    },
    {
      "id": "cmp_kpi_row",
      "type": "container",
      "props": {
        "direction": "horizontal",
        "gap": 12
      },
      "children": ["cmp_kpi_mrr", "cmp_kpi_active_users"]
    },
    {
      "id": "cmp_kpi_mrr",
      "type": "text",
      "props": {
        "content": "MRR: ¥1.2M"
      }
    },
    {
      "id": "cmp_kpi_active_users",
      "type": "text",
      "props": {
        "content": "活跃用户: 12,430"
      }
    },
    {
      "id": "cmp_revenue_chart",
      "type": "chart",
      "props": {
        "title": "收入趋势",
        "kind": "line"
      }
    }
  ],
  "data": {
    "entities": [
      {
        "id": "session",
        "shape": {
          "userId": "string",
          "role": "string"
        }
      }
    ],
    "queries": [
      {
        "id": "q_bootstrap",
        "source": "local"
      }
    ],
    "states": [
      {
        "id": "loading",
        "type": "boolean",
        "initial": false
      }
    ]
  },
  "actions": [
    {
      "id": "act_dashboard_load",
      "trigger": {
        "type": "load"
      },
      "effects": [
        {
          "type": "run_query",
          "queryId": "q_bootstrap"
        }
      ]
    }
  ],
  "design": {
    "theme": "light",
    "tokens": {
      "colorPrimary": "#2563eb",
      "radiusMd": 8,
      "spacingUnit": 4
    },
    "breakpoints": {
      "sm": 640,
      "md": 768,
      "lg": 1024
    }
  },
  "constraints": [
    {
      "kind": "a11y",
      "rule": "interactive_requires_label",
      "level": "error"
    },
    {
      "kind": "performance",
      "rule": "first_screen_components_under_30",
      "level": "warn"
    }
  ]
}
