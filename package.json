{
  "name": "prd2prototype",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint test typecheck build",
    "pipeline": "pnpm --filter @prd2prototype/planner pipeline",
    "patch": "pnpm --filter @prd2prototype/evaluator patch"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.2",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3"
  }
}
