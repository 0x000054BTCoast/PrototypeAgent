{
  "name": "prd2prototype",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run typecheck",
    "typecheck": "npm run typecheck:packages && npm run typecheck:web",
    "typecheck:packages": "tsc --noEmit -p tsconfig.packages.json",
    "typecheck:web": "tsc --noEmit -p apps/web-preview/tsconfig.json",
    "pipeline": "npm run pipeline -w @prd2prototype/planner",
    "patch": "npm run patch -w @prd2prototype/evaluator"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
