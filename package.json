{
  "name": "prd2prototype",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "eslint . --cache --max-warnings=0",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint test typecheck build",
    "pipeline": "pnpm --filter @prd2prototype/planner pipeline",
    "patch": "pnpm --filter @prd2prototype/evaluator patch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck:strict": "tsc -p tsconfig.json --noEmit && tsc -p apps/web-preview/tsconfig.json --noEmit",
    "prepare": "husky",
    "baseline": "tsx scripts/baseline-run.ts",
    "eval:parser": "tsx scripts/parser-eval.ts",
    "dag": "tsx scripts/generate-dag.ts",
    "quality:gate": "tsx scripts/quality-gate.ts",
    "quality:gate:strict": "tsx scripts/quality-gate.ts --max-retries 3",
    "quality:gate:ci": "tsx scripts/quality-gate.ts --max-retries 1 --min-success-rate 0.95 --min-editable-stability-rate 0.95 --min-baseline-score 0.9 --max-duration-ms 180000",
    "runs:prune": "pnpm --filter @prd2prototype/planner runs:prune"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.2",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,jsx,json,md,yml,yaml,css}": [
      "prettier --write"
    ],
    "*.{js,cjs,mjs,ts,tsx,jsx}": [
      "eslint --fix --max-warnings=0"
    ]
  }
}
