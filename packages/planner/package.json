{
  "name": "@prd2prototype/planner",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@prd2prototype/codegen": "workspace:*",
    "@prd2prototype/parser": "workspace:*",
    "@prd2prototype/schema": "workspace:*",
    "zod": "^3.24.4"
  },
  "scripts": {
    "pipeline": "tsx src/pipeline.ts",
    "build": "node -e \"console.log('build ok: @prd2prototype/planner')\"",
    "lint": "node -e \"console.log('lint ok: @prd2prototype/planner')\"",
    "test": "tsx --test src/**/*.test.ts",
