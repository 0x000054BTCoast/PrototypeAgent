{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@prd2prototype/schema": [
        "packages/schema/src/index.ts"
      ]
    }
  },
  "include": [
    "packages/**/*.ts"
  ]
}
